# --- Server ---
PORT=4000
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=8h

# --- Database (SQLite for local dev — just a file, no server/install) ---
# When moving to production with real ZoneMinder hardware, swap this section
# for MariaDB (see src/config/db.js comments) and use sql/schema.sql instead
# of sql/schema.sqlite.sql.
DB_FILE=./data/safeguardsecurity.db

# --- ZoneMinder server this deployment talks to ---
ZM_BASE_URL=https://ground-station.example.com/zm
ZM_API_USER=safeguard_security_service
ZM_API_PASSWORD=replace-me
# ZM API auth style differs by version — 'legacy' (username/password login.json)
# or 'token' (OAuth2-style access/refresh tokens, ZM 1.34+)
ZM_AUTH_MODE=token

# Allowed origin for the two frontend consoles (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:8081
